# GravitySearch Backend Environment Variables

# The port the Node.js server will run on (Render/Railway handles this automatically)
PORT=5000

# Your MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/search_engine
MONGO_URI=

# Your Redis Cache Connection String (e.g., from Upstash or Render Redis)
# Example: redis://default:password@eu1-choice-macaw-123.upstash.io:32412
REDIS_URL=

# The URL of your deployed Vercel frontend (for CORS protection)
# Example: https://gravity-search-frontend.vercel.app
CLIENT_URL=
