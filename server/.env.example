# Search Engine Crawler — Environment Variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/search_engine
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/search_engine
MONGO_URI=mongodb://localhost:27017/search_engine

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── Crawler Defaults (optional — values are also enforced in the controller) ──
# MAX_DEPTH=2
# MAX_PAGES=50
